{
  "name": "cafeteria-testes",
  "version": "1.0.0",
  "description": "Testes centralizados do projeto Cafeteria CodeQual",
  "main": "index.js",
  "scripts": {
    "test": "jest --config=jest.config.js",
    "test:unit": "jest --config=jest.config.js --testMatch='**/unitarios/**/*.test.js'",
    "test:unit:backend": "jest --config=jest.config.js --testMatch='**/unitarios/backend/**/*.test.js'",
    "test:unit:frontend": "jest --config=jest.config.js --testMatch='**/unitarios/frontend/**/*.test.js'",
    "test:integration": "NODE_ENV=test jest unitarios/integracao",
    "test:integration:api": "jest --config=jest.integration.js --testMatch='**/integracao/api/**/*.test.js'",
    "test:integration:fluxos": "jest --config=jest.integration.js --testMatch='**/integracao/fluxos/**/*.test.js'",
    "test:watch": "jest --config=jest.config.js --watch",
    "test:coverage": "jest --config=jest.config.js --coverage",
    "test:coverage:html": "jest --config=jest.config.js --coverage --coverageReporters=html",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:ci": "npm run test:coverage -- --ci --maxWorkers=2"
  },
  "keywords": [
    "testes",
    "jest",
    "cafeteria"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.12",
    "axios": "^1.6.7",
    "babel-jest": "^30.3.0",
    "dotenv": "^17.3.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "pg": "^8.11.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "supertest": "^6.3.4"
  }
}
